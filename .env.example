# Arbitrum One RPC endpoint. On the source VDS, dRPC and PublicNode
# were the ones that actually worked reliably; Alchemy was IP-blocked
# for that specific VDS (403 from an anti-abuse gateway) and Infura/Ankr
# rate-limited quickly on free tier. Re-verify with a quick curl test
# before trusting any of them again -- provider behavior shifts.
ARBITRUM_RPC_URL=https://arbitrum.drpc.org

# Optional: comma-separated list of RPC URLs for historical_scan_triangular.py
# to rotate through when one fails (429/408/-32603/usage-limit errors). Only
# used by the batch scanner, not simulate_triangular_arbitrage.py. Without
# this, the scanner still retries on failure but keeps hitting the same
# single provider, which does nothing for a real quota/usage-limit error
# (as opposed to a transient one) -- add a second provider here if you're
# seeing a high SKIPPED rate in a scan.
# ARBITRUM_RPC_URLS=https://arbitrum.drpc.org,https://arbitrum-one-rpc.publicnode.com

# Chain ID for Arbitrum One
CHAIN_ID=42161

# EVM hardfork name passed to `anvil --hardfork=`. degenbot/newer Anvil
# combos can reject "latest" outright -- if you hit "Error: Unknown
# hardfork: latest", run `anvil --help | grep -A5 hardfork` to see what
# your installed anvil accepts.
ANVIL_HARDFORK=cancun

# Caps how fast Anvil is allowed to hit your RPC provider for missing
# storage/state. Free-tier providers return 429/408 if this is too
# high -- lower it if you see that. 10 worked reasonably on the source
# VDS against dRPC/Infura; tune per provider.
ANVIL_COMPUTE_UNITS_PER_SECOND=10

# How long (seconds) to wait for anvil to come up before giving up. At
# low ANVIL_COMPUTE_UNITS_PER_SECOND, anvil's own startup calls are
# throttled too and can take well over the old 20s default.
ANVIL_STARTUP_TIMEOUT=90
